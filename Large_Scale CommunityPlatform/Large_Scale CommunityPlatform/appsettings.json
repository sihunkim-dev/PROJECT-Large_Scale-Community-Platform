{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings" : {
    "Secret" : "local-development-secret-key-must-be-at-least-32-characters",
    "Issuer" : "LargeScaleCommunityPlatform",
    "Audience" : "LargeScaleCommunityPlatformClient",
    "ExpiryMinutes" : 60
  },
  "RedisOption": {
    "Configuration" : "localhost"
  }
}
